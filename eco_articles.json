[{"url": "https://www.theguardian.com/business/2026/mar/25/uk-inflation-rate-energy-price-jump-iran-war", "title": "\u0406\u043d\u0444\u043b\u044f\u0446\u0456\u044f \u0443 \u0412\u0435\u043b\u0438\u043a\u0456\u0439 \u0411\u0440\u0438\u0442\u0430\u043d\u0456\u0457 \u0437\u0430\u043b\u0438\u0448\u0438\u043b\u0430\u0441\u044f \u043d\u0430 \u0440\u0456\u0432\u043d\u0456 3%", "summary": "\u0420\u0456\u0447\u043d\u0438\u0439 \u0440\u0456\u0432\u0435\u043d\u044c \u0456\u043d\u0444\u043b\u044f\u0446\u0456\u0457 \u0443 \u0412\u0435\u043b\u0438\u043a\u0456\u0439 \u0411\u0440\u0438\u0442\u0430\u043d\u0456\u0457 \u0437\u0430\u043b\u0438\u0448\u0438\u0438\u0432\u0441\u044f \u0431\u0435\u0437 \u0437\u043c\u0456\u043d \u043d\u0430 \u0440\u0456\u0432\u043d\u0456 3% \u0443 \u043b\u044e\u0442\u043e\u043c\u0443. \u0426\u0435 \u0432\u0456\u0434\u0431\u0443\u043b\u043e\u0441\u044f \u043f\u0435\u0440\u0435\u0434 \u0442\u0438\u043c, \u044f\u043a \u0432\u0456\u0439\u043d\u0430 \u0432 \u0406\u0440\u0430\u043d\u0456 \u043f\u0456\u0434\u043d\u044f\u043b\u0430 \u0433\u043b\u043e\u0431\u0430\u043b\u044c\u043d\u0456 \u0435\u043d\u0435\u0440\u0433\u0435\u0442\u0438\u0447\u043d\u0456 \u0432\u0438\u0442\u0440\u0430\u0442\u0438.", "country": "uk", "type": "inflation", "ts": "2026-03-25T07:16:52"}, {"url": "https://asia.nikkei.com/business/energy/china-oil-demand-to-approach-peak-this-year-cnooc-economist-says", "title": "\u041f\u043e\u043f\u0438\u0442 \u043d\u0430 \u043d\u0430\u0444\u0442\u0443 \u0432 \u041a\u0438\u0442\u0430\u0457 \u043d\u0430\u0431\u043b\u0438\u0437\u0438\u0442\u044c\u0441\u044f \u0434\u043e \u043f\u0456\u043a\u0443 \u0446\u044c\u043e\u0433\u043e \u0440\u043e\u043a\u0443", "summary": "\u0417\u0430 \u043f\u0440\u043e\u0433\u043d\u043e\u0437\u0430\u043c\u0438 \u0435\u043a\u043e\u043d\u043e\u043c\u0456\u0441\u0442\u0430 \u043a\u043e\u043c\u043f\u0430\u043d\u0456\u0457 CNOOC, \u043f\u043e\u043f\u0438\u0442 \u043d\u0430 \u043d\u0430\u0444\u0442\u0443 \u0432 \u041a\u0438\u0442\u0430\u04