u043b\u0438", "\u0404\u043c\u0435\u043d \u0445\u0443\u0441\u0438\u0442\u0441\u044c\u043a\u0456 \u0443\u0434\u0430\u0440\u0438 \u0431\u0435\u0437\u043f\u0456\u043b\u043e\u0442\u043d\u0438\u043a\u0430\u043c\u0438", "\u0421\u0438\u0440\u0456\u044f \u0440\u043e\u0441\u0456\u0439\u0441\u044c\u043a\u0456 \u0430\u0432\u0456\u0430\u0443\u0434\u0430\u0440\u0438", "\u0415\u0444\u0456\u043e\u043f\u0456\u044f \u0422\u0438\u0433\u0440\u0430\u0439 \u0430\u0440\u0442\u0438\u043b\u0435\u0440\u0456\u0439\u0441\u044c\u043a\u0438\u0439 \u0432\u043e\u0433\u043e\u043d\u044c", "\u0421\u043e\u043c\u0430\u043b\u0456 \u0410\u043b\u044c-\u0428\u0430\u0431\u0430\u0431 \u0437\u0430\u0441\u0456\u0434\u043a\u0438", "\u0410\u0444\u0433\u0430\u043d\u0456\u0441\u0442\u0430\u043d \u0422\u0430\u043b\u0456\u0431\u0430\u043d \u0434\u043e\u0440\u043e\u0436\u043d\u0456 \u0432\u0438\u0431\u0443\u0445\u043e\u0432\u0456 \u043f\u0440\u0438\u0441\u0442\u0440\u043e\u0457", "\u041d\u0430\u0433\u0456\u0440\u043d\u0438\u0439 \u041a\u0430\u0440\u0430\u0431\u0430\u0445 \u043f\u043e\u0440\u0443\u0448\u0435\u043d\u043d\u044f \u0440\u0435\u0436\u0438\u043c\u0443 \u043f\u0440\u0438\u043f\u0438\u043d\u0435\u043d\u043d\u044f \u0432\u043e\u0433\u043d\u044e", "\u0421\u0443\u0434\u0430\u043d \u0414\u0430\u0440\u0444\u0443\u0440 \u0441\u0443\u0442\u0438\u0447\u043a\u0438 \u043f\u043e\u0432\u0441\u0442\u0430\u043d\u0446\u0456\u0432"]}